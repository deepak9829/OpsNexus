# ============================================================
# OpsNexus Environment Variables — copy to .env and fill in
# NEVER commit .env to version control
# ============================================================

# ============================================================
# --- Database (MySQL 8.0) ---
# ============================================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=localhost
MYSQL_PORT=3306

# ============================================================
# --- MongoDB 7.0 ---
# ============================================================
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=documents_db

# ============================================================
# --- DynamoDB / LocalStack ---
# ============================================================
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
DYNAMODB_NOTIFICATIONS_TABLE=notifications
DYNAMODB_AUDIT_TABLE=audit_events

# ============================================================
# --- Auth Service :8081 ---
# ============================================================
AUTH_SERVICE_PORT=8081
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass
# JWT_SECRET must be at least 32 characters in production
JWT_SECRET=change-me-in-production-use-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

# ============================================================
# --- Tenant Service :8082 ---
# ============================================================
TENANT_SERVICE_PORT=8082
TENANT_DB_NAME=tenant_db
TENANT_DB_USER=tenant_user
TENANT_DB_PASSWORD=tenant_pass

# ============================================================
# --- Workflow Service :8083 ---
# ============================================================
WORKFLOW_SERVICE_PORT=8083
WORKFLOW_DB_NAME=workflow_db
WORKFLOW_DB_USER=workflow_user
WORKFLOW_DB_PASSWORD=workflow_pass

# ============================================================
# --- Document Service :8084 ---
# ============================================================
DOCUMENT_SERVICE_PORT=8084

# ============================================================
# --- Notification Service :8085 ---
# ============================================================
NOTIFICATION_SERVICE_PORT=8085

# ============================================================
# --- Frontend (Vite) ---
# ============================================================
VITE_API_BASE_URL=http://localhost:8080
VITE_AUTH_SERVICE_URL=http://localhost:8081
VITE_TENANT_SERVICE_URL=http://localhost:8082
VITE_WORKFLOW_SERVICE_URL=http://localhost:8083
VITE_DOCUMENT_SERVICE_URL=http://localhost:8084
VITE_NOTIFICATION_SERVICE_URL=http://localhost:8085
