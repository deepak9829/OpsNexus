# ============================================================
# Go
# ============================================================

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test binary
*.test

# Go coverage output
*.out
coverage.out
coverage.html

# Go build output
/bin/
/dist/
services/*/bin/
services/*/*.out

# Vendor directory
vendor/

# Go workspace sum file (generated)
go.work.sum

# Module download cache (not typically committed)
# Keep go.sum but ignore these:
__debug_bin*

