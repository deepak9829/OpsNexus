# Workflow Service Configuration

# Server
SERVER_PORT=8083
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# Database - MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=workflow_user
DB_PASSWORD=workflow_password
DB_NAME=workflow_db

# Alternatively, provide full DSN:
# DATABASE_URL=workflow_user:workflow_password@tcp(localhost:3306)/workflow_db?charset=utf8mb4&parseTime=True&loc=UTC

# Database pool settings
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Logging
LOG_LEVEL=info
LOG_JSON=true
